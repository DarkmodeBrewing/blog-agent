{
  "name": "blog-agent",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 127.0.0.1 --port 5173 --strictPort",
    "dev:proxy": "DEV_SERVER_BASE=/proxy/5173/ DEV_SERVER_ORIGIN=https://code.darkmode.tools DEV_SERVER_HMR_HOST=code.darkmode.tools DEV_SERVER_HMR_PROTOCOL=wss DEV_SERVER_HMR_CLIENT_PORT=443 DEV_SERVER_HMR_PATH=/proxy/5173 vite dev --host 127.0.0.1 --port 5173 --strictPort",
    "rebuild:native": "npm rebuild better-sqlite3",
    "dev:network": "vite dev --host 0.0.0.0 --port 5173 --strictPort",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/basic-auth": "^1.1.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7"
  },
  "dependencies": {
    "basic-auth": "^2.0.1",
    "better-sqlite3": "^12.9.0",
    "dompurify": "^3.4.0",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.0.2",
    "marked": "^18.0.2",
    "octokit": "^5.0.5",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  }
}
